{
  "name": "autosales-ai",
  "version": "0.1.0",
  "private": true,
  "description": "AutoSales AI - Autonomous B2B Sales Development Agent for ADIKAM",
  "author": "ADIKAM Sp. z o.o.",
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "dev": "pnpm --filter autosales-web dev",
    "web:dev": "pnpm --filter autosales-web dev",
    "build": "pnpm --filter autosales-web build",
    "web:build": "pnpm --filter autosales-web build",
    "start": "pnpm --filter autosales-web start",
    "web:start": "pnpm --filter autosales-web start",
    "lint": "pnpm --filter autosales-web lint",
    "web:lint": "pnpm --filter autosales-web lint",
    "agent:setup": "bash scripts/agent_setup.sh",
    "agent:lint": "bash scripts/agent_setup.sh && cd packages/agent && .venv/bin/python -m ruff check .",
    "agent:test": "bash scripts/agent_setup.sh && cd packages/agent && .venv/bin/python -m pytest",
    "db:migrate": "bash scripts/db_migrate.sh",
    "db:seed": "bash scripts/db_seed.sh",
    "agent:dev": "bash scripts/agent_setup.sh && cd packages/agent && .venv/bin/uvicorn autosales.main:app --reload --port 8000",
    "agent:start": "bash scripts/agent_setup.sh && cd packages/agent && .venv/bin/uvicorn autosales.main:app --host 0.0.0.0 --port 8000 --workers 2",
    "docker:up": "docker compose -f docker/docker-compose.yml up -d",
    "docker:down": "docker compose -f docker/docker-compose.yml down",
    "docker:dev": "docker compose -f docker/docker-compose.yml -f docker/docker-compose.dev.yml up",
    "docker:logs": "docker compose -f docker/docker-compose.yml logs -f"
  }
}
