# ============================================================
# AutoSales AI - Environment Configuration
# ============================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ============================================================

# ------------------------------------------------------------
# LLM PROVIDER CONFIGURATION
# ------------------------------------------------------------
# Default provider and model (format: "provider/model")
# Providers: "anthropic" | "openai" | "openai-codex"
# Examples: "anthropic/claude-sonnet-4-6", "openai/gpt-4o", "openai-codex/gpt-5.4"
LLM_PROVIDER=anthropic
LLM_MODEL=anthropic/claude-sonnet-4-6

# --- Anthropic (Claude) ---
# Required if using anthropic provider
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- OpenAI (API Key) ---
# Required if using openai provider (pay-per-token)
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- OpenAI Codex (ChatGPT Subscription) ---
# Use your ChatGPT Plus ($20/mo) or Pro ($200/mo) subscription!
# No API billing - flat rate included in subscription
# Run: autosales providers auth login --provider openai-codex
# This will open browser for ChatGPT OAuth login
OPENAI_CODEX_CLIENT_ID=your_oauth_client_id
OPENAI_CODEX_REDIRECT_URI=http://localhost:3000/api/auth/callback/codex
# Tokens are stored in ~/.autosales/auth-profiles.json after OAuth login
# Subscription tier: "plus" (5h/week) | "pro" (unlimited)
OPENAI_CODEX_SUBSCRIPTION_TIER=plus

# --- Auth Profile Storage ---
# Where to store provider credentials (default: ~/.autosales/auth-profiles.json)
AUTH_PROFILES_PATH=~/.autosales/auth-profiles.json

# --- Provider Fallback Chain ---
# Comma-separated provider IDs. If primary fails, tries next in chain.
# Example: "openai-codex,anthropic,openai"
PROVIDER_FALLBACK_CHAIN=anthropic,openai

# ------------------------------------------------------------
# DATABASE
# ------------------------------------------------------------
# PostgreSQL connection string (used by agent + web)
DATABASE_URL=postgresql://autosales:your_secure_password@localhost:5432/autosales

# Supabase (optional - for hosted DB + auth + realtime)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=eyJxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SUPABASE_SERVICE_ROLE_KEY=eyJxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Next.js public variables (used by CRM frontend)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ------------------------------------------------------------
# EMAIL PROVIDER
# ------------------------------------------------------------
# Which email provider to use: "imap" | "outlook" | "gmail"
EMAIL_PROVIDER=imap

# --- IMAP / SMTP (generic) ---
IMAP_HOST=imap.your-provider.com
IMAP_PORT=993
IMAP_USER=sales@yourdomain.com
IMAP_PASSWORD=your_email_password
IMAP_USE_SSL=true

SMTP_HOST=smtp.your-provider.com
SMTP_PORT=587
SMTP_USER=sales@yourdomain.com
SMTP_PASSWORD=your_email_password
SMTP_USE_TLS=true

# --- Microsoft Outlook / Office 365 ---
# Azure AD App Registration credentials
OUTLOOK_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
OUTLOOK_CLIENT_SECRET=your_client_secret
OUTLOOK_TENANT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
OUTLOOK_USER_EMAIL=sales@yourdomain.com
# Scopes: Mail.ReadWrite, Mail.Send, User.Read
OUTLOOK_REDIRECT_URI=http://localhost:3000/api/auth/callback/outlook

# --- Gmail ---
# Google Cloud OAuth2 credentials
GMAIL_CLIENT_ID=xxxxxxxxxxxx.apps.googleusercontent.com
GMAIL_CLIENT_SECRET=GOCSPx-xxxxxxxxxxxxxxxxxxxxx
GMAIL_REFRESH_TOKEN=1//xxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GMAIL_USER_EMAIL=sales@yourdomain.com

# ------------------------------------------------------------
# AGENT CONFIGURATION
# ------------------------------------------------------------
# How often the agent checks for new tasks (in minutes)
HEARTBEAT_INTERVAL_MINUTES=30

# Directory containing agent personality, knowledge, and prompts
AGENT_CONFIG_DIR=./agent-config

# Maximum emails to send per hour (rate limiting)
AGENT_MAX_EMAILS_PER_HOUR=20

# Maximum research tasks to run concurrently
AGENT_MAX_CONCURRENT_RESEARCH=5

# Log level: DEBUG | INFO | WARNING | ERROR
AGENT_LOG_LEVEL=INFO

# ------------------------------------------------------------
# APPLICATION SETTINGS
# ------------------------------------------------------------
# Next.js frontend public API URL (for client-side requests)
NEXT_PUBLIC_API_URL=http://localhost:3000/api

# Agent API URL (FastAPI backend)
AGENT_API_URL=http://localhost:8000

# JWT secret for inter-service auth
JWT_SECRET=generate_a_strong_random_secret_here

# Application domain (used for CORS, callbacks)
APP_DOMAIN=localhost

# ------------------------------------------------------------
# CRM INTEGRATION (optional)
# ------------------------------------------------------------
# Pipedrive
PIPEDRIVE_API_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxx
PIPEDRIVE_DOMAIN=your-company.pipedrive.com

# ------------------------------------------------------------
# MONITORING & NOTIFICATIONS (optional)
# ------------------------------------------------------------
# Slack webhook for agent notifications
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx/xxx/xxx

# Sentry DSN for error tracking
SENTRY_DSN=https://xxxxx@sentry.io/xxxxx
